# ==============================================
# Salin file ini menjadi .env lalu isi nilainya:
#   cp .env-example .env && chmod 600 .env
# ==============================================

# Timezone
TZ=Asia/Jakarta

# --- n8n ---
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
N8N_PORT=5678
# Wajib diisi. Generate dengan: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# SMTP (opsional — kosongkan N8N_EMAIL_MODE jika tidak dipakai)
N8N_EMAIL_MODE=
N8N_SMTP_HOST=
N8N_SMTP_PORT=587
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=

# --- WAHA ---
WAHA_HOST=waha.example.com
WAHA_PROTOCOL=https
WAHA_PORT=3000
# Engine: NOWEB (ringan, tanpa browser), WEBJS, atau GOWS
WHATSAPP_DEFAULT_ENGINE=NOWEB
# Generate dengan: openssl rand -hex 32
WAHA_API_KEY=
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=
